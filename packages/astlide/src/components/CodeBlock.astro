---
/**
 * CodeBlock — enhanced code block wrapper with filename bar and copy button.
 *
 * Wraps a fenced code block (```lang ... ```) in MDX with a styled header
 * showing an optional filename and a one-click copy-to-clipboard button.
 *
 * Usage in MDX:
 *   <CodeBlock title="src/content.config.ts">
 *   ```typescript
 *   const foo = 'bar';
 *   ```
 *   </CodeBlock>
 *
 * Props:
 *   title — optional filename/label shown in the header bar
 *   class — extra CSS classes on the wrapper
 */
interface Props {
	title?: string;
	class?: string;
}

const { title, class: className } = Astro.props;
// Unique ID so the copy button targets only its own <pre> element
const uid = `cb-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={['code-block', className]} id={uid}>
  <div class="code-block-header">
    {title && <span class="code-block-title">{title}</span>}
    <button
      class="code-block-copy"
      data-cb={uid}
      type="button"
      aria-label="Copy code to clipboard"
    >Copy</button>
  </div>
  <div class="code-block-content">
    <slot />
  </div>
</div>

<style>
  .code-block {
    border-radius: var(--radius, 8px);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.9em;
    margin: 0.5em 0;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 1rem;
    background: rgba(0, 0, 0, 0.35);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 2.25rem;
  }

  .code-block-title {
    font-size: 0.8rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    color: rgba(255, 255, 255, 0.65);
  }

  .code-block-copy {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
    line-height: 1.4;
  }

  .code-block-copy:hover {
    background: rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.9);
  }

  .code-block-copy[data-copied] {
    background: rgba(74, 222, 128, 0.15);
    border-color: rgba(74, 222, 128, 0.35);
    color: rgb(74, 222, 128);
  }

  .code-block-content :global(pre) {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .code-block-copy {
      transition: none;
    }
  }
</style>

<script>
  // Use event delegation so dynamically-inserted code blocks are also handled
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement)?.closest<HTMLButtonElement>('.code-block-copy');
    if (!btn) return;
    const id = btn.getAttribute('data-cb');
    const block = id ? document.getElementById(id) : null;
    const pre = block?.querySelector('pre');
    if (!pre) return;
    try {
      await navigator.clipboard.writeText(pre.textContent ?? '');
      btn.textContent = '✓ Copied!';
      btn.setAttribute('data-copied', '');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.removeAttribute('data-copied');
      }, 2000);
    } catch {
      // Clipboard API unavailable — show brief failure feedback
      btn.textContent = 'Failed';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    }
  });
</script>

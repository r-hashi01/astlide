---
import '../styles/base.css';
import '../styles/themes/default.css';

interface Props {
  title: string;
  theme?: string;
  currentSlide: number;
  totalSlides: number;
  deck: string;
  notes?: string;
}

const { title, theme = 'default', currentSlide, totalSlides, deck, notes } = Astro.props;
const progress = (currentSlide / totalSlides) * 100;
const isPresenter = Astro.url.searchParams.has('presenter');
---

<!DOCTYPE html>
<html lang="en" data-theme={theme} data-presenter={isPresenter ? 'true' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body data-total-slides={totalSlides} data-current-slide={currentSlide}>

    <!-- Progress bar -->
    <div class="progress-bar" style={`width: ${progress}%`} aria-hidden="true"></div>

    {isPresenter ? (
      <!-- Presenter mode layout -->
      <div class="presenter-layout">
        <div class="presenter-slide-area">
          <div class="presenter-current">
            <div class="slide-scaler" id="slide-scaler"><slot /></div>
          </div>
        </div>
        <aside class="presenter-panel">
          <div class="presenter-info">
            <span class="presenter-counter">{currentSlide} / {totalSlides}</span>
            <span class="presenter-timer" id="presenter-timer">00:00</span>
          </div>
          <div class="presenter-notes">
            <h3>Notes</h3>
            {notes
              ? <div class="notes-content" set:html={notes} />
              : <p class="no-notes">No notes for this slide.</p>
            }
          </div>
          <div class="presenter-nav">
            <a href={currentSlide > 1 ? `/${deck}/${currentSlide - 1}?presenter` : undefined}
               class:list={['pnav-btn', { disabled: currentSlide <= 1 }]}>← Prev</a>
            <a href={currentSlide < totalSlides ? `/${deck}/${currentSlide + 1}?presenter` : undefined}
               class:list={['pnav-btn', { disabled: currentSlide >= totalSlides }]}>Next →</a>
          </div>
        </aside>
      </div>
    ) : (
      <!-- Normal presentation layout -->
      <div class="presentation">
        <div class="slide-scaler" id="slide-scaler"><slot /></div>
      </div>
    )}

    <!-- Navigation (hidden until hover, not shown in presenter) -->
    {!isPresenter && (
      <nav class="slide-nav" aria-label="Slide navigation">
        <a href={currentSlide > 1 ? `/${deck}/${currentSlide - 1}` : undefined}
           class:list={['nav-btn', { disabled: currentSlide <= 1 }]}
           aria-label="Previous slide">←</a>
        <span class="nav-indicator">{currentSlide} / {totalSlides}</span>
        <a href={currentSlide < totalSlides ? `/${deck}/${currentSlide + 1}` : undefined}
           class:list={['nav-btn', { disabled: currentSlide >= totalSlides }]}
           aria-label="Next slide">→</a>
      </nav>
    )}

    <!-- Notes overlay (toggled with 'n') -->
    {!isPresenter && notes && (
      <div class="notes-overlay" id="notes-overlay" aria-hidden="true">
        <div class="notes-overlay-content">
          <div class="notes-overlay-header">
            <span>Speaker Notes</span>
            <button class="notes-close" id="notes-close">✕</button>
          </div>
          <div class="notes-body" set:html={notes} />
        </div>
      </div>
    )}

    <!-- Overview mode overlay -->
    <div class="overview" id="overview" aria-hidden="true">
      <div class="overview-header">
        Overview — press <kbd>o</kbd> or <kbd>Esc</kbd> to close
      </div>
      <div class="overview-grid" id="overview-grid"></div>
    </div>

    <script define:vars={{ currentSlide, totalSlides, deck, isPresenter }}>
      // ── 1. Viewport scaling ────────────────────────────────────
      const scaler = document.getElementById('slide-scaler');
      const slideEl = scaler ? scaler.querySelector('.slide') : null;

      function updateScale() {
        if (!slideEl || !scaler) return;
        const rootStyle = getComputedStyle(document.documentElement);
        const rawW = rootStyle.getPropertyValue('--slide-width').trim();
        const rawH = rootStyle.getPropertyValue('--slide-height').trim();
        const slideW = parseFloat(rawW) || 1920;
        const slideH = parseFloat(rawH) || 1080;

        let availW, availH;
        if (isPresenter) {
          const area = document.querySelector('.presenter-current');
          availW = area ? area.clientWidth : window.innerWidth * 0.65;
          availH = area ? area.clientHeight : window.innerHeight;
        } else {
          availW = window.innerWidth;
          availH = window.innerHeight;
        }

        const scale = Math.min(availW / slideW, availH / slideH);
        scaler.style.width = slideW + 'px';
        scaler.style.height = slideH + 'px';
        scaler.style.transform = 'scale(' + scale + ')';
      }

      updateScale();
      window.addEventListener('resize', updateScale);

      // ── 2. Fragment support ────────────────────────────────────
      const fragments = Array.from(document.querySelectorAll('[data-fragment]')).sort(
        (a, b) =>
          parseInt(a.getAttribute('data-fragment-index') || '0') -
          parseInt(b.getAttribute('data-fragment-index') || '0')
      );
      let currentFragment = -1;

      function showNextFragment() {
        if (currentFragment < fragments.length - 1) {
          currentFragment++;
          fragments[currentFragment].setAttribute('data-fragment-visible', 'true');
          return true;
        }
        return false;
      }

      function showPrevFragment() {
        if (currentFragment >= 0) {
          fragments[currentFragment].removeAttribute('data-fragment-visible');
          currentFragment--;
          return true;
        }
        return false;
      }

      // ── 3. Navigation ──────────────────────────────────────────
      function goNext() {
        if (fragments.length > 0 && showNextFragment()) return;
        if (currentSlide < totalSlides)
          window.location.href = '/' + deck + '/' + (currentSlide + 1) + (isPresenter ? '?presenter' : '');
      }

      function goPrev() {
        if (fragments.length > 0 && showPrevFragment()) return;
        if (currentSlide > 1)
          window.location.href = '/' + deck + '/' + (currentSlide - 1) + (isPresenter ? '?presenter' : '');
      }

      // ── 4. Overview mode ───────────────────────────────────────
      const overview = document.getElementById('overview');
      const overviewGrid = document.getElementById('overview-grid');
      let overviewOpen = false;

      function openOverview() {
        if (!overview) return;
        overviewOpen = true;
        overview.setAttribute('aria-hidden', 'false');
        overview.classList.add('open');
        if (overviewGrid && overviewGrid.children.length === 0) {
          for (let i = 1; i <= totalSlides; i++) {
            const item = document.createElement('a');
            item.href = '/' + deck + '/' + i;
            item.className = 'overview-item' + (i === currentSlide ? ' current' : '');
            item.setAttribute('aria-label', 'Slide ' + i);

            const iframe = document.createElement('iframe');
            iframe.src = '/' + deck + '/' + i;
            iframe.setAttribute('sandbox', 'allow-same-origin allow-scripts');
            iframe.setAttribute('scrolling', 'no');
            iframe.tabIndex = -1;
            iframe.setAttribute('aria-hidden', 'true');
            item.appendChild(iframe);

            const label = document.createElement('span');
            label.className = 'overview-item-label';
            label.textContent = String(i);
            item.appendChild(label);

            overviewGrid.appendChild(item);
          }
        }
      }

      function closeOverview() {
        if (!overview) return;
        overviewOpen = false;
        overview.setAttribute('aria-hidden', 'true');
        overview.classList.remove('open');
      }

      if (overview) overview.addEventListener('click', (e) => { if (e.target === overview) closeOverview(); });

      // ── 5. Notes overlay ───────────────────────────────────────
      const notesOverlay = document.getElementById('notes-overlay');
      const notesClose = document.getElementById('notes-close');
      let notesOpen = false;

      function toggleNotes() {
        if (!notesOverlay) return;
        notesOpen = !notesOpen;
        notesOverlay.setAttribute('aria-hidden', String(!notesOpen));
        notesOverlay.classList.toggle('open', notesOpen);
      }

      if (notesClose) notesClose.addEventListener('click', toggleNotes);

      // ── 6. Presenter timer ─────────────────────────────────────
      const timerEl = document.getElementById('presenter-timer');
      if (timerEl) {
        const startTime = Date.now();
        setInterval(() => {
          const elapsed = Math.floor((Date.now() - startTime) / 1000);
          const m = String(Math.floor(elapsed / 60)).padStart(2, '0');
          const s = String(elapsed % 60).padStart(2, '0');
          timerEl.textContent = m + ':' + s;
        }, 1000);
      }

      // ── 7. Keyboard shortcuts ──────────────────────────────────
      document.addEventListener('keydown', function(e) {
        if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

        if (overviewOpen) {
          if (e.key === 'Escape' || e.key === 'o') closeOverview();
          return;
        }

        switch (e.key) {
          case 'ArrowRight':
          case ' ':
            e.preventDefault();
            goNext();
            break;
          case 'ArrowLeft':
            e.preventDefault();
            goPrev();
            break;
          case 'ArrowUp':
          case 'Home':
            e.preventDefault();
            window.location.href = '/' + deck + '/1' + (isPresenter ? '?presenter' : '');
            break;
          case 'ArrowDown':
          case 'End':
            e.preventDefault();
            window.location.href = '/' + deck + '/' + totalSlides + (isPresenter ? '?presenter' : '');
            break;
          case 'f':
            if (!isPresenter) document.documentElement.requestFullscreen && document.documentElement.requestFullscreen();
            break;
          case 'Escape':
            if (document.fullscreenElement) document.exitFullscreen && document.exitFullscreen();
            else if (notesOpen) toggleNotes();
            break;
          case 'o':
            if (!isPresenter) openOverview();
            break;
          case 'p':
            if (!isPresenter) {
              const u = new URL(window.location.href);
              u.searchParams.set('presenter', '');
              window.open(u.toString(), 'astlide-presenter', 'width=1280,height=800,menubar=no,toolbar=no,status=no');
            }
            break;
          case 'n':
            if (!isPresenter) toggleNotes();
            break;
        }
      });

      // ── 8. Touch / swipe support ───────────────────────────────
      let touchStartX = 0;
      let touchStartY = 0;

      document.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].clientX;
        touchStartY = e.changedTouches[0].clientY;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) < 30 && Math.abs(dy) < 30) return;
        if (Math.abs(dx) > Math.abs(dy)) {
          if (dx < 0) goNext();
          else goPrev();
        }
      }, { passive: true });
    </script>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    overflow: hidden;
    width: 100vw;
    height: 100vh;
    background: #000;
  }

  /* ── Progress bar ── */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--color-primary, #3b82f6);
    z-index: 200;
    transition: width 0.25s ease;
    pointer-events: none;
  }

  /* ── Normal presentation ── */
  .presentation {
    width: 100vw;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #000;
  }

  .slide-scaler {
    transform-origin: center center;
    flex-shrink: 0;
  }

  /* ── Presenter layout ── */
  [data-presenter] {
    overflow: hidden;
  }

  .presenter-layout {
    display: flex;
    width: 100vw;
    height: 100vh;
    background: #111;
  }

  .presenter-slide-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
    padding: 1rem;
  }

  .presenter-current {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .presenter-panel {
    width: 360px;
    flex-shrink: 0;
    background: #1a1a2e;
    border-left: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    color: #e0e0e0;
    font-family: system-ui, sans-serif;
    overflow: hidden;
  }

  .presenter-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .presenter-counter {
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  .presenter-timer {
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    color: #60a5fa;
    font-family: monospace;
  }

  .presenter-notes {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
  }

  .presenter-notes h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .notes-content,
  .presenter-notes .notes-body {
    font-size: 1rem;
    line-height: 1.6;
    color: #cbd5e1;
  }

  .no-notes {
    color: #475569;
    font-style: italic;
    font-size: 0.9rem;
  }

  .presenter-nav {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .pnav-btn {
    flex: 1;
    padding: 0.6rem;
    text-align: center;
    background: rgba(255,255,255,0.08);
    color: #e0e0e0;
    text-decoration: none;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .pnav-btn:hover:not(.disabled) { background: rgba(255,255,255,0.16); }
  .pnav-btn.disabled { opacity: 0.25; pointer-events: none; }

  /* ── Navigation bar ── */
  .slide-nav {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1.25rem;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 2rem;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  body:hover .slide-nav {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-btn {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: white;
    text-decoration: none;
    font-size: 1.1rem;
    transition: background 0.15s;
  }

  .nav-btn:hover:not(.disabled) { background: rgba(255, 255, 255, 0.25); }
  .nav-btn.disabled { opacity: 0.25; pointer-events: none; }

  .nav-indicator {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    min-width: 3.5rem;
    text-align: center;
    font-family: monospace;
  }

  /* ── Notes overlay ── */
  .notes-overlay {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35vh;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 300;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
  }

  .notes-overlay.open {
    transform: translateY(0);
  }

  .notes-overlay-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.5);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: system-ui, sans-serif;
    flex-shrink: 0;
  }

  .notes-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    font-size: 1rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    transition: color 0.15s;
  }
  .notes-close:hover { color: white; }

  .notes-body {
    padding: 1rem 1.5rem;
    overflow-y: auto;
    flex: 1;
    color: #cbd5e1;
    font-family: system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.6;
  }

  /* ── Overview mode ── */
  .overview {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 500;
    display: none;
    flex-direction: column;
    overflow-y: auto;
  }

  .overview.open { display: flex; }

  .overview-header {
    padding: 1.25rem 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
    font-size: 0.875rem;
    font-family: system-ui, sans-serif;
    flex-shrink: 0;
  }

  .overview-header kbd {
    display: inline-block;
    padding: 0.1em 0.4em;
    background: rgba(255,255,255,0.15);
    border-radius: 0.25em;
    font-family: monospace;
    font-size: 0.85em;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    padding: 1.5rem 2rem;
  }

  .overview-item {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 0.5rem;
    overflow: hidden;
    text-decoration: none;
    border: 2px solid transparent;
    transition: border-color 0.15s, transform 0.15s;
    display: block;
    background: #111;
  }

  .overview-item:hover { border-color: rgba(255,255,255,0.4); transform: translateY(-2px); }
  .overview-item.current { border-color: var(--color-primary, #3b82f6); }

  .overview-item iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 1920px;
    height: 1080px;
    transform: scale(0.1354);
    transform-origin: top left;
    pointer-events: none;
    border: none;
  }

  .overview-item-label {
    position: absolute;
    bottom: 0.4rem;
    right: 0.6rem;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.75);
    background: rgba(0,0,0,0.55);
    padding: 0.1em 0.45em;
    border-radius: 1em;
    font-family: monospace;
    font-variant-numeric: tabular-nums;
  }

  /* ── Print ── */
  @media print {
    .slide-nav, .progress-bar, .overview, .notes-overlay { display: none !important; }
    .presentation { background: transparent; }
    .slide-scaler { transform: none !important; width: 100% !important; height: 100% !important; }
  }
</style>

---
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import { deckConfigSchema } from '@astlide/core/schema';

declare const __ASTLIDE_CSP__: boolean | string;

const DEFAULT_CSP = [
  "default-src 'self'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "font-src 'self' https://fonts.gstatic.com",
  "img-src 'self' data: https:",
  "connect-src 'self'",
  "frame-src 'self'",
].join('; ');

const cspOption: boolean | string =
  typeof __ASTLIDE_CSP__ !== 'undefined' ? __ASTLIDE_CSP__ : true;
const cspContent =
  cspOption === false ? null
  : typeof cspOption === 'string' && cspOption !== 'true' ? cspOption
  : DEFAULT_CSP;

// Get all deck directories
const decksDir = path.join(process.cwd(), 'src', 'content', 'decks');
const deckNames = fs.readdirSync(decksDir).filter((name) => {
  const stat = fs.statSync(path.join(decksDir, name));
  return stat.isDirectory();
});

// Load deck configs
const decks = await Promise.all(
  deckNames.map(async (name) => {
    const configPath = path.join(decksDir, name, '_config.json');
    let config = deckConfigSchema.parse({});  // schema defaults

    if (fs.existsSync(configPath)) {
      try {
        const raw = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
        const result = deckConfigSchema.safeParse(raw);
        if (result.success) {
          config = result.data;
        }
        // Invalid _config.json values — schema defaults remain in effect
      } catch {
        // Malformed JSON — schema defaults remain in effect
      }
    }

    // Count slides
    const slides = await getCollection('decks', (entry) =>
      entry.id.startsWith(`${name}/`)
    );

    // Parse date safely — skip if the value is not a valid date
    const rawDate = config.date ?? null;
    const parsedDate = rawDate
      ? (() => { const d = new Date(rawDate); return Number.isNaN(d.getTime()) ? null : d; })()
      : null;
    const formattedDate = parsedDate ? parsedDate.toLocaleDateString() : null;

    return {
      name,
      title:  config.title ?? name,   // string: falls back to deck directory name
      author: config.author,
      theme:  config.theme,
      slideCount: slides.length,
      formattedDate,
    };
  })
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {cspContent && <meta http-equiv="Content-Security-Policy" content={cspContent} />}
    <title>Slide Decks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <h1>Slide Decks</h1>

      <div class="deck-grid">
        {decks.map((deck) => (
          <a href={`/${deck.name}/1`} class="deck-card">
            <h2>{deck.title}</h2>
            {deck.author && <p class="author">{deck.author}</p>}
            {deck.formattedDate && <p class="date">{deck.formattedDate}</p>}
            <p class="slides">{deck.slideCount} slides</p>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #0f172a;
    color: #f8fafc;
    min-height: 100vh;
    padding: 4rem 2rem;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .deck-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .deck-card {
    display: block;
    padding: 2rem;
    background: #1e293b;
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .deck-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .deck-card h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #f8fafc;
  }

  .deck-card .author {
    color: #94a3b8;
    font-size: 0.875rem;
  }

  .deck-card .date {
    color: #64748b;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  .deck-card .slides {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #334155;
    color: #3b82f6;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>

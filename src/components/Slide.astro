---
interface Props {
  layout?: string;
  transition?: string;
  background?: string;
  class?: string;
  slideNumber?: number;
  totalSlides?: number;
}

const {
  layout = 'default',
  transition = 'fade',
  background,
  class: className,
  slideNumber,
  totalSlides,
} = Astro.props;

const backgroundStyle = background
  ? background.startsWith('url(')
    ? `background-image: ${background}; background-size: cover; background-position: center;`
    : `background-color: ${background};`
  : '';
---

<section
  class:list={['slide', `slide-${layout}`, className]}
  data-transition={transition}
  data-slide={slideNumber}
  style={backgroundStyle}
>
  <div class="slide-content">
    <slot />
  </div>
  
  {slideNumber && totalSlides && (
    <div class="slide-number">
      {slideNumber} / {totalSlides}
    </div>
  )}
</section>

<style>
  .slide {
    width: var(--slide-width, 1920px);
    height: var(--slide-height, 1080px);
    padding: var(--slide-padding, 4rem);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  .slide-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--content-gap, 2rem);
  }

  .slide-number {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-size: var(--font-size-small);
    color: var(--color-secondary);
    font-variant-numeric: tabular-nums;
  }

  /* Cover layout */
  .slide-cover {
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .slide-cover .slide-content {
    justify-content: center;
    align-items: center;
  }

  /* Section layout */
  .slide-section {
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .slide-section .slide-content {
    justify-content: center;
    align-items: center;
  }

  /* Two-column layout */
  .slide-two-column .slide-content {
    flex-direction: row;
  }

  /* Code layout */
  .slide-code {
    padding: 2rem;
  }

  .slide-code .slide-content {
    gap: 1rem;
  }

  /* Quote layout */
  .slide-quote {
    justify-content: center;
    align-items: center;
  }

  .slide-quote .slide-content {
    max-width: 80%;
    text-align: center;
  }

  /* Image full layout */
  .slide-image-full {
    padding: 0;
  }

  .slide-image-full .slide-content {
    padding: var(--slide-padding);
    justify-content: flex-end;
  }

  /* Text utilities */
  .slide.text-light {
    color: #ffffff;
  }

  .slide.text-dark {
    color: #1a1a1a;
  }
</style>
